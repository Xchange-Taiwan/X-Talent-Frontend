NEXT_PUBLIC_API_URL=

# BFF OpenAPI schema URL — used by `pnpm generate:types` to regenerate src/types/api.ts
# Store actual value in .env (gitignored)
BFF_OPENAPI_URL=

# API client feature flag — set to true once backend JWT auth is fully configured
NEXT_PUBLIC_USE_API_CLIENT=false

NEXTAUTH_URL=http://localhost:3000/
NEXTAUTH_SECRET=secret

# Sentry DSN — get from https://sentry.io → Project Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=

# Google Analytics 4 Measurement ID — get from GA4 → Admin → Data Streams → Measurement ID
# Format: G-XXXXXXXXXX. Leave empty to disable GA4.
NEXT_PUBLIC_GA_ID=

# Microsoft Clarity project ID — get from https://clarity.microsoft.com → Settings
# Leave empty to disable Clarity (e.g. in local development)
NEXT_PUBLIC_CLARITY_ID=

# Playwright E2E test account credentials — use a dedicated test account, never a real user
# Store actual values in .env.e2e.local (gitignored) or CI secrets
E2E_EMAIL=
E2E_PASSWORD=
